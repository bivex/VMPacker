# VMPacker Test Runner (x86_64)
FROM --platform=linux/amd64 golang:1.25-trixie AS builder

WORKDIR /work

# Install build dependencies for CGO (stub compilation)
RUN apt-get update && apt-get install -y \
    gcc \
    binutils \
    make \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Copy go mod files first for better caching
COPY go.mod go.sum* ./
RUN go mod download

# Copy source
COPY . .

# Build stubs (optional, for full integration tests)
# RUN make stub64 stub32

# Run tests
CMD ["go", "test", "./...", "-v"]
