# Sample Target Makefile
# This Makefile demonstrates how to compile a target for ARM64 and protect it.

CROSS   ?= aarch64-linux-gnu-
CC       = $(CROSS)gcc
PACKER   = ../build/vmpacker

TARGET   = demo_simple
SRC      = demo_simple.c
PROTECTED = $(TARGET).vmp

# Docker configuration
DOCKER_IMAGE = debian:latest
DOCKER_RUN   = docker run --rm --platform linux/arm64 -v "$(shell pwd)":/app -w /app

.PHONY: all clean protect run-docker

all: $(TARGET)

$(TARGET): $(SRC)
	$(CC) -static -O1 -nostdlib -march=armv8-a $< -o $@
	@echo "[+] Built target: $@"

# Protect the 'check_simple' function
protect: $(TARGET)
	@if [ ! -f $(PACKER) ]; then echo "Error: vmpacker not found. Run 'make packer' in the root directory first."; exit 1; fi
	$(PACKER) -func check_simple -v -o $(PROTECTED) $(TARGET)
	@echo "[+] Protected binary created: $(PROTECTED)"

# Run using Docker (requires Docker Desktop on Mac)
run-docker: $(PROTECTED)
	@echo "Running protected binary in Docker..."
	@$(DOCKER_RUN) $(DOCKER_IMAGE) bash -c "chmod +x ./$(PROTECTED) && ./$(PROTECTED); echo 'Exit code (expected 37): $$?'"

clean:
	rm -f $(TARGET) $(PROTECTED)
