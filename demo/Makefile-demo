# Sample Target Makefile
# This Makefile demonstrates how to compile a target for ARM64 and protect it.

CROSS   ?= aarch64-linux-gnu-
CC       = $(CROSS)gcc
PACKER   = ../build/vmpacker

TARGET   = demo_simple
TARGET_C = demo_complex
SRC      = demo_simple.c
SRC_C    = demo_complex.c
PROTECTED = $(TARGET).vmp
PROTECTED_C = $(TARGET_C).vmp

# Docker configuration
DOCKER_IMAGE = debian:latest
DOCKER_RUN   = docker run --rm --platform linux/arm64 -v "$(shell pwd)":/app -w /app

.PHONY: all clean protect run-docker run-complex

all: $(TARGET) $(TARGET_C)

$(TARGET): $(SRC)
	$(CC) -static -O1 -nostdlib -march=armv8-a $< -o $@
	@echo "[+] Built target: $@"

$(TARGET_C): $(SRC_C)
	$(CC) -static -O1 -nostdlib -march=armv8-a $< -o $@
	@echo "[+] Built complex target: $@"

# Protect both functions
protect: $(TARGET) $(TARGET_C)
	@if [ ! -f $(PACKER) ]; then echo "Error: vmpacker not found. Run 'make packer' in the root directory first."; exit 1; fi
	$(PACKER) -func check_simple -v -o $(PROTECTED) $(TARGET)
	$(PACKER) -func check_complex -v -o $(PROTECTED_C) $(TARGET_C)
	@echo "[+] Protected binaries created."

# Run using Docker
run-docker: $(PROTECTED)
	@echo "Running simple demo in Docker..."
	@$(DOCKER_RUN) $(DOCKER_IMAGE) bash -c "chmod +x ./$(PROTECTED) && ./$(PROTECTED); echo 'Exit code (expected 37): $$?'"

run-complex: $(PROTECTED_C)
	@echo "Running complex patterns demo (FPU/SIMD/JumpTable) in Docker..."
	@$(DOCKER_RUN) $(DOCKER_IMAGE) bash -c "chmod +x ./$(PROTECTED_C) && ./$(PROTECTED_C); echo 'Exit code (expected 97): $$?'"

clean:
	rm -f $(TARGET) $(TARGET_C) $(PROTECTED) $(PROTECTED_C)
